#!/bin/sh
# Eggs skill launcher — POSIX shell, no Python required.
#
# Downloads the right pre-built `eggs` binary for the current OS/arch on
# first use, then re-execs from a per-user cache on every subsequent call.
# Periodically compares the hash recorded at download time against the
# server's latest SHA256SUMS so a new release gets picked up automatically;
# no local sha tool is needed (no `shasum`/`sha256sum` dependency).
#
# Layout:
#   ~/.eggs/bin/eggs         cached binary (chmod +x)
#   ~/.eggs/bin/eggs.sha256  server's expected hash, written at download time
#   ~/.eggs/bin/.verified    touch'd whenever stored hash last matched server
#
# Override:
#   EGGS_RELEASE_URL         base URL, defaults to GitHub Releases
#   EGGS_BIN_DIR             cache directory, defaults to ~/.eggs/bin
#   EGGS_VERIFY_INTERVAL     seconds between SHA256SUMS checks, default 600
#   EGGS_SKIP_VERIFY=1       always trust the cache (offline / CI)
#
# The companion `eggs.cmd` next to this script is the Windows equivalent.

set -eu

RELEASE_URL="${EGGS_RELEASE_URL:-https://github.com/larchliu/eggs/releases/latest/download}"
BIN_DIR="${EGGS_BIN_DIR:-$HOME/.eggs/bin}"
CACHE="$BIN_DIR/eggs"
EXPECTED_HASH_FILE="$BIN_DIR/eggs.sha256"
VERIFIED_MARKER="$BIN_DIR/.verified"
VERIFY_INTERVAL="${EGGS_VERIFY_INTERVAL:-600}"

# Map (os, arch) -> release asset filename. macOS ships a single universal
# Mach-O so we don't care about arm64 vs x86_64 on Mac. Resolved up here so
# the verify path can use it before any download.
os="$(uname -s)"
arch="$(uname -m)"
case "$os" in
    Darwin)
        asset="eggs-darwin-universal"
        ;;
    Linux)
        case "$arch" in
            x86_64|amd64)  asset="eggs-linux-x86_64" ;;
            aarch64|arm64) asset="eggs-linux-arm64"  ;;
            *) echo "eggs: unsupported Linux arch '$arch'" >&2; exit 1 ;;
        esac
        ;;
    *) echo "eggs: unsupported OS '$os' (use eggs.cmd on Windows)" >&2; exit 1 ;;
esac

download() {
    if command -v curl >/dev/null 2>&1; then
        curl -fL --progress-bar -o "$2" "$1"
    elif command -v wget >/dev/null 2>&1; then
        wget --show-progress -qO "$2" "$1"
    else
        echo "eggs: need curl or wget on PATH to download the binary" >&2
        return 127
    fi
}

# Echo the expected SHA256 for $asset from the server's SHA256SUMS to stdout,
# or empty string on any failure (network down, asset missing from sums).
fetch_server_hash() {
    sums_tmp="$(mktemp 2>/dev/null || echo "/tmp/eggs.sums.$$")"
    if download "$RELEASE_URL/SHA256SUMS" "$sums_tmp" >/dev/null 2>&1; then
        awk -v a="$asset" '$2 == a { print $1; exit }' "$sums_tmp"
    fi
    rm -f "$sums_tmp"
}

# 0 if the verify marker is fresher than VERIFY_INTERVAL or skip-verify is set.
verify_recent() {
    if [ "${EGGS_SKIP_VERIFY:-0}" = "1" ]; then
        return 0
    fi
    [ -f "$VERIFIED_MARKER" ] || return 1
    now=$(date +%s 2>/dev/null) || return 1
    # GNU stat takes -c, BSD stat takes -f; try both, fall back to "no info"
    # which forces a re-verify.
    mtime=$(stat -c %Y "$VERIFIED_MARKER" 2>/dev/null \
        || stat -f %m "$VERIFIED_MARKER" 2>/dev/null \
        || echo 0)
    [ "$mtime" -gt 0 ] || return 1
    [ "$now" -ge "$mtime" ] && [ $((now - mtime)) -lt "$VERIFY_INTERVAL" ]
}

mark_verified() {
    mkdir -p "$BIN_DIR"
    : > "$VERIFIED_MARKER" 2>/dev/null || true
}

record_hash() {
    # $1 = hash to record. Empty string is a no-op.
    [ -n "$1" ] || return 0
    mkdir -p "$BIN_DIR"
    printf '%s\n' "$1" > "$EXPECTED_HASH_FILE"
}

# Fast path: cache + marker is fresh (or skip-verify is set).
if [ -x "$CACHE" ] && verify_recent; then
    exec "$CACHE" "$@"
fi

# Cache present but verify TTL expired — compare stored hash to server.
if [ -x "$CACHE" ]; then
    server_hash="$(fetch_server_hash)"
    if [ -z "$server_hash" ]; then
        # SHA256SUMS unreachable / asset not listed. Trust the cache, but
        # don't touch the marker so the next launch tries again.
        echo "eggs: version check unavailable; using cached binary" >&2
        exec "$CACHE" "$@"
    fi
    if [ -r "$EXPECTED_HASH_FILE" ]; then
        stored_hash="$(awk '{print $1; exit}' "$EXPECTED_HASH_FILE" 2>/dev/null || true)"
        if [ -n "$stored_hash" ] && [ "$stored_hash" = "$server_hash" ]; then
            mark_verified
            exec "$CACHE" "$@"
        fi
        echo "eggs: cached binary differs from latest release; re-downloading" >&2
    else
        # Pre-existing cache from before the verify scheme (or someone
        # dropped a binary in by hand). Force a fresh download so we have
        # a hash on file.
        echo "eggs: no recorded hash for cached binary; re-downloading" >&2
    fi
    # Fall through to re-download.
fi

# A pre-existing `eggs` on PATH (Eggs.app installed manually, or a previous
# `cli_install` symlink) is still preferred over re-downloading.
if command -v eggs >/dev/null 2>&1 && [ "$(command -v eggs)" != "$CACHE" ]; then
    exec eggs "$@"
fi

mkdir -p "$BIN_DIR"
url="$RELEASE_URL/$asset"
tmp="$CACHE.tmp"
echo "eggs: downloading $url" >&2
if ! download "$url" "$tmp"; then
    rm -f "$tmp"
    echo "eggs: download failed" >&2
    exit 1
fi
chmod +x "$tmp"
mv "$tmp" "$CACHE"

# Record the server's hash for our asset alongside the binary so subsequent
# launches can verify by comparing stored vs fresh SHA256SUMS line. If the
# sums file is unreachable we leave the file absent (next launch will treat
# it as "no record" and re-download once SHA256SUMS comes back).
record_hash "$(fetch_server_hash)"
mark_verified
echo "eggs: cached at $CACHE" >&2

exec "$CACHE" "$@"
